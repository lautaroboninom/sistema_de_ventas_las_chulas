# --- DEV (Docker Compose) ---

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS/CSRF (separado por coma)
ALLOWED_ORIGINS=http://localhost:5175
FRONTEND_ORIGIN=http://localhost:5175
PUBLIC_WEB_URL=http://localhost:5175

TZ=America/Argentina/Buenos_Aires

# Branding
COMPANY_NAME=Sistema de Reparaciones
COMPANY_CODE=DEFAULT
COMPANY_HEADER_L1=
COMPANY_HEADER_L2=
COMPANY_HEADER_L3=
COMPANY_FOOTER_EMAIL=
COMPANY_FOOTER_CUIT=
COMPANY_FOOTER_WEB=
COMPANY_FOOTER_WHATSAPP=
