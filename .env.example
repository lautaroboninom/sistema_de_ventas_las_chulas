 # ===== PostgreSQL (dev con Docker) =====
 DB_VENDOR=postgresql
 POSTGRES_DB=servicio_tecnico
 POSTGRES_USER=sepid
 POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
 POSTGRES_HOST=postgres
 POSTGRES_PORT=5432
 TZ=America/Argentina/Buenos_Aires
 
 # ===== Django / App =====
 DJANGO_SECRET_KEY=CHANGE_ME_SECURE
 DJANGO_DEBUG=true
 DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
 ALLOWED_ORIGINS=http://localhost:5173
 AUDIT_LOG_EXCLUDE_PREFIXES=/api/ping,/api/auth/login,/api/auth/forgot,/api/auth/reset
 
 # JWT (si corresponde)
 JWT_SECRET=dev-jwt-secret
 JWT_TTL_HOURS=24
 
 # Email (SMTP de testing o real)
 EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
 EMAIL_HOST=mail.example.com
 EMAIL_PORT=587
 EMAIL_HOST_USER=no-reply@example.com
 EMAIL_HOST_PASSWORD=
 EMAIL_USE_TLS=1
 DEFAULT_FROM_EMAIL="SEPID Reparaciones (DEV) <no-reply@example.com>"
 
 # PDF / Branding
 LOGO_PATH=/code/service/static/logo.png
 
 # Media de ingresos
 INGRESO_MEDIA_MAX_SIZE_MB=10
 INGRESO_MEDIA_MAX_FILES=50
 INGRESO_MEDIA_THUMB_MAX=512
 INGRESO_MEDIA_ALLOWED_MIME=image/jpeg,image/png
 INGRESO_MEDIA_STORAGE_PREFIX=ingresos
 
 # Observabilidad (opcional)
 SENTRY_DSN=
 LOG_LEVEL=DEBUG
 
 # Presupuestos (PDFs)
 QUOTES_HOST_DIR=./quotes
 QUOTES_SAVE_DIR=/quotes
 
 # Seguridad login
 TOKEN_TTL_MIN=30
 EMAIL_COOLDOWN_MIN=1
 LOGIN_MAX_ATTEMPTS=5
 LOGIN_LOCKOUT_MINUTES=5
 PASSWORD_MIN_LENGTH=10
 
