# ===== PostgreSQL (dev con Docker) =====
DB_VENDOR=postgresql
POSTGRES_DB=servicio_tecnico
POSTGRES_USER=sepid
POSTGRES_PASSWORD=Valdenegro4578.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
TZ=America/Argentina/Buenos_Aires

# ===== Django =====
DJANGO_SECRET_KEY=changeme-super-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS/CSRF (con esquema). Incluí tu Vite/IP LAN si accedés desde otro equipo.
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_WEB_URL=http://localhost:5173

# Branding / estáticos
LOGO_PATH=/code/service/static/logo.png

# === Media de ingresos ===
INGRESO_MEDIA_MAX_SIZE_MB=10
INGRESO_MEDIA_MAX_FILES=50
INGRESO_MEDIA_THUMB_MAX=512
INGRESO_MEDIA_ALLOWED_MIME=image/jpeg,image/png
INGRESO_MEDIA_STORAGE_PREFIX=ingresos

# ===== Presupuestos (PDFs) =====
QUOTES_HOST_DIR=./quotes
QUOTES_SAVE_DIR=/quotes
