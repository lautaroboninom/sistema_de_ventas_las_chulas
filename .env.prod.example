# --- PROD (secure template) ---
# 1) Copy this file to .env.prod
# 2) Run:
#    powershell -ExecutionPolicy Bypass -File .\deploy\rotate_secrets.ps1 -EnvFile .env.prod

# Django
DJANGO_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
DJANGO_DEBUG=false
PUBLIC_HOST=retailhub.tailcee59c.ts.net
DJANGO_ALLOWED_HOSTS=retailhub.tailcee59c.ts.net
ALLOWED_ORIGINS=https://retailhub.tailcee59c.ts.net
FRONTEND_ORIGIN=https://retailhub.tailcee59c.ts.net
PUBLIC_WEB_URL=https://retailhub.tailcee59c.ts.net
TZ=America/Argentina/Buenos_Aires

# Security / session / auth
AUTH_COOKIE_NAME=auth_token
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=1
PASSWORD_MIN_LENGTH=10
JWT_TTL_MIN=240
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_MAX=10
FORGOT_RATE_LIMIT_MAX=5
AUTH_RATE_WINDOW_SECONDS=60
TRUST_PROXY_HEADERS=1
REDIS_URL=redis://redis:6379/1
AUDIT_LOG_ENABLED=1
AUDIT_LOG_MAX_BODY=2048

# Branding
COMPANY_NAME=Las Chulas
COMPANY_CODE=DEFAULT
COMPANY_HEADER_L1=
COMPANY_HEADER_L2=
COMPANY_HEADER_L3=
COMPANY_FOOTER_EMAIL=
COMPANY_FOOTER_CUIT=
COMPANY_FOOTER_WEB=
COMPANY_FOOTER_WHATSAPP=
LOGO_PATH=/app/staticfiles/branding/logo-app.png

# PostgreSQL
POSTGRES_DB=las_chulas_retail
POSTGRES_USER=las_chulas_postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=120

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_INSECURE_SKIP_VERIFY=0
DEFAULT_FROM_EMAIL=no-reply@example.com

# Frontend build args
VITE_API_URL=
VITE_APP_NAME=Las Chulas
VITE_COMPANY_LEGAL=Las Chulas
VITE_SOURCEMAP=0
VITE_SW=0

# TLS certs (host) for docker-compose.prod.yml
TLS_CERTS_HOST_DIR=./certs

# Retail - ARCA (WSFEv1)
ARCA_WS_ENV=prod
ARCA_WSFE_MOCK=0
ARCA_DEFAULT_PTO_VTA=1
ARCA_DEFAULT_TIPO_CBTE=6
ARCA_CUIT=
ARCA_CERT_PATH=
ARCA_KEY_PATH=
ARCA_WSAA_SERVICE=wsfe

# Retail - Tienda Nube
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=
TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_WEBHOOK_SECRET=
TIENDANUBE_API_BASE=https://api.tiendanube.com/2025-03
TIENDANUBE_USER_AGENT=LasChulasRetail (admin@localhost)
TIENDANUBE_TIMEOUT_SECS=15
