# ===== Django / App (no secrets real) =====
DJANGO_SECRET_KEY=CHANGE_ME_SECURE
DJANGO_DEBUG=false

# Hostnames/IPs comma-separated (no scheme)
DJANGO_ALLOWED_HOSTS=reparaciones.sepid.com.ar

# Browser origins with scheme (used for CSRF/CORS)
ALLOWED_ORIGINS=https://reparaciones.sepid.com.ar

# Branding / URLs
FRONTEND_ORIGIN=https://reparaciones.sepid.com.ar
PUBLIC_WEB_URL=https://reparaciones.sepid.com.ar

# Audit
AUDIT_LOG_EXCLUDE_PREFIXES=/api/ping,/api/health,/api/auth/login,/api/auth/forgot,/api/auth/reset

# JWT (if used by service.auth)
JWT_SECRET=CHANGE_ME_JWT
JWT_TTL_HOURS=24

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_USER=sepid
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=servicio_tecnico
MYSQL_HOST=mysql
MYSQL_PORT=3306
TZ=America/Argentina/Buenos_Aires

# ===== Email (SMTP) =====
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@sepid.com.ar
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL="SEPID Reparaciones <no-reply@sepid.com.ar>"

# ===== Presupuestos (PDFs) =====
# Host path where API will store copies of generated PDFs (optional)
# Example (Linux):   QUOTES_HOST_DIR=/mnt/presupuestos/2025/Pendientes
# Example (Windows): QUOTES_HOST_DIR=Z:\\MG BIO\\1 PRESUPUESTOS MGBIO SA\\2025\\Pendientes de envío
QUOTES_HOST_DIR=
QUOTES_SAVE_DIR=/quotes

# ===== Frontend build =====
# If set, baked into Vite build; otherwise frontend uses same-origin /api
VITE_API_URL=https://reparaciones.sepid.com.ar

# ===== Traefik ACME email (Let's Encrypt)
# Used by Traefik to register/renew certificates. Not secret.
TRAEFIK_ACME_EMAIL=ops@example.com
