# --- PROD (Internet / Traefik) ---

# Public host (usado por Traefik labels y Django settings_internet)
PUBLIC_HOST=example.com
TRAEFIK_ACME_EMAIL=ops@example.com

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=example.com
ALLOWED_ORIGINS=https://example.com
FRONTEND_ORIGIN=https://example.com
PUBLIC_WEB_URL=https://example.com
TZ=America/Argentina/Buenos_Aires

# Branding
COMPANY_NAME=Sistema de Reparaciones
COMPANY_CODE=DEFAULT
COMPANY_HEADER_L1=
COMPANY_HEADER_L2=
COMPANY_HEADER_L3=
COMPANY_FOOTER_EMAIL=
COMPANY_FOOTER_CUIT=
COMPANY_FOOTER_WEB=
COMPANY_FOOTER_WHATSAPP=
LOGO_PATH=/app/staticfiles/branding/logo-app.png

# PostgreSQL
POSTGRES_DB=servicio_tecnico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Email (opcional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=no-reply@example.com
BAJA_NOTIFY_RECIPIENTS=
ASSIGNMENT_REQUEST_RECIPIENTS=

# Volúmenes / mounts (host)
QUOTES_HOST_DIR=./quotes
REPUESTOS_COSTOS_HOST_DIR=./repuestos

# Frontend build args (opcional)
VITE_API_URL=
VITE_APP_NAME=Sistema de Reparaciones
VITE_COMPANY_LEGAL=Sistema de Reparaciones

