MYSQL_PASSWORD=supersegura
# Nota: definir MYSQL_ROOT_PASSWORD solo fuera del repo

# Frontend (build-time)
# Si se desea forzar URL del API en tiempo de build (por fuera del mismo origen):
# VITE_API_URL=http://api-staging:8000

# ===== Auditoría =====
AUDIT_LOG_ENABLED=1
AUDIT_LOG_MAX_BODY=4096
AUDIT_LOG_EXCLUDE_PREFIXES=/api/ping,/api/auth/login,/api/auth/forgot,/api/auth/reset

# ===== Branding =====
