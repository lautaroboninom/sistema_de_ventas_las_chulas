TZ=America/Argentina/Buenos_Aires

ALLOWED_ORIGINS=http://localhost:5173,http://192.168.50.5


# MySQL (staging)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=servicio_tecnico
