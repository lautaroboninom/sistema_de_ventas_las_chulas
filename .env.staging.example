# --- STAGING (PostgreSQL) ---

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
ALLOWED_ORIGINS=https://staging.reparacionesequilux
FRONTEND_ORIGIN=https://staging.reparacionesequilux
PUBLIC_WEB_URL=https://staging.reparacionesequilux
TZ=America/Argentina/Buenos_Aires
BAJA_NOTIFY_RECIPIENTS=serviciotecnico@equiluxmd.com

# PostgreSQL (staging)
DB_VENDOR=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=servicio_tecnico
POSTGRES_USER=equilux_app
POSTGRES_PASSWORD=CHANGE_ME

# Frontend (build-time)
# VITE_API_URL=https://staging.reparacionesequilux/api

# Presupuestos (PDFs) - opcional
QUOTES_HOST_DIR=./quotes

# Repuestos (costos)
REPUESTOS_COSTOS_HOST_DIR=C:/repuestos_costos
REPUESTOS_COSTOS_ROOT=/repuestos
REPUESTOS_COSTOS_FILE=/repuestos/COSTOS VIGENTES.xlsx
