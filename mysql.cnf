[mysqld]
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

# Modo estricto y requisitos de claves primarias
sql_mode = STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
innodb_strict_mode = ON
sql_require_primary_key = ON

# Habilitar importación local (ETL)
local_infile = ON

# Zona horaria fija (evita depender de tablas TZ)
default-time-zone = '-03:00'

# MySQL 8.0 ya tiene explicit_defaults_for_timestamp=ON por defecto
# explicit_defaults_for_timestamp = ON  # (documentado; mantener comentado)

