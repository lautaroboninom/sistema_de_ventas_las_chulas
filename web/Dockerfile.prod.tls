FROM node:20-alpine AS builder
WORKDIR /app

# Dependencies layer
COPY package*.json ./
RUN npm install --no-audit --no-fund

# Build with optional API base and flags passed at build time
ARG VITE_API_URL
ARG VITE_SOURCEMAP
ARG VITE_SW
ENV BROWSERSLIST_IGNORE_OLD_DATA=1
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_SOURCEMAP=${VITE_SOURCEMAP}
ENV VITE_SW=${VITE_SW}

COPY . .
RUN npm run build

FROM nginx:alpine AS server
WORKDIR /

# Nginx conf for SPA + static + TLS termination
COPY --chown=root:root --from=builder /app/dist /usr/share/nginx/html
COPY --chown=root:root deploy/web.nginx.tls.conf /etc/nginx/conf.d/default.conf

EXPOSE 80 443
CMD ["nginx", "-g", "daemon off;"]
