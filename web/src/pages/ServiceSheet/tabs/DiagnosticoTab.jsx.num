0020:  // fecha servicio
0021:  fechaServStr,
0022:  setFechaServStr,
0023:  maxLocalNow,
0024:  // resolucion
0025:  canResolve,
0026:  resolucion,
0027:  setResolucion,
0028:  // permisos
0029:  actAsTech,
0030:  canEditDiag,
0031:  canMarkReparado,
0032:  // helpers
0033:  patch,
