0117:          <div className="text-xs uppercase text-gray-500 mb-1">Informe preliminar</div>
0118:          <div className="whitespace-pre-wrap">{data.informe_preliminar || "-"}</div>
0119:        </div>
0120:        <div className="border rounded p-3 bg-gray-50">
0121:          <div className="text-xs uppercase text-gray-500 mb-1">Accesorios</div>
