0035:  refreshIngreso,
0036:  setShowReparadoToast,
0037:  savingDiag,
0038:  // fotos
0039:  canManagePhotos,
0040:}) {
0041:  const [addingAcc, setAddingAcc] = useState(false);
0042:  const [deletingAccId, setDeletingAccId] = useState(null);
0043:  const [savingAll, setSavingAll] = useState(false);
0044:  const [savingResol, setSavingResol] = useState(false);
0045:
0046:
0047:  async function addAccesorio() {
0048:    try {
0049:      const d = (nuevoAcc?.descripcion || "").trim().toLowerCase();
0050:      if (!d) { setErr("EscribÃ­ una descripciÃ³n"); return; }
0051:      const acc = (accesCatalogo || []).find(a => (a?.nombre || "").trim().toLowerCase() === d);
0052:      if (!acc) { setErr("ElegÃ­ una descripciÃ³n vÃ¡lida de la lista"); return; }
0053:      setAddingAcc(true);
0054:      await postAccesorioIngreso(id, {
0055:        accesorio_id: Number(acc.id),
0056:        referencia: (nuevoAcc?.referencia || "").trim() || null,
0057:      });
0058:      setNuevoAcc && setNuevoAcc({ descripcion: "", referencia: "" });
0059:      await refreshIngreso();
0060:      setErr("");
0061:    } catch (e) {
0062:      setErr(e?.message || "No se pudo agregar el accesorio");
0063:    } finally {
0064:      setAddingAcc(false);
0065:    }
0066:  }
0067:
0068:  async function removeAccesorio(itemId) {
0069:    try {
