0001:import Row from "../../../components/Row";
0002:import IngresoPhotos from "../../../components/IngresoPhotos";
0003:import { RESOLUCION_OPTIONS } from "../../../lib/constants";
0004:import { postMarcarReparado, postCerrarReparacion, postAccesorioIngreso, deleteAccesorioIngreso } from "../../../lib/api";
0005:import { useState } from "react";
0006:
0007:export default function DiagnosticoTab({
0008:  id,
0009:  data,
0010:  // accesorios
0011:  canEditAcc,
0012:  accesCatalogo,
0013:  nuevoAcc,
