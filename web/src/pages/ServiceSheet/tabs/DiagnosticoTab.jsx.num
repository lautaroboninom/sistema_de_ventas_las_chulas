0075:      setErr(e?.message || "No se pudo quitar el accesorio");
0076:    } finally {
0077:      setDeletingAccId(null);
0078:    }
0079:  }
0080:
0081:  async function saveDiagYreparacion() {
0082:    try {
0083:      setSavingAll(true);
0084:      const payload = {
0085:        descripcion_problema: descripcion,
0086:        trabajos_realizados: trabajos,
0087:        fecha_servicio: (fechaServStr || "").trim() || null,
0088:      };
0089:      await patch(payload);
0090:      await refreshIngreso();
0091:      setErr("");
0092:    } catch (e) {
0093:      setErr(e?.message || "No se pudo guardar");
0094:    } finally {
0095:      setSavingAll(false);
0096:    }
0097:  }
0098:
0099:  async function saveResolucion() {
0100:    try {
0101:      if (!resolucion) { setErr("SeleccionÃ¡ una resoluciÃ³n."); return; }
0102:      setSavingResol(true);
0103:      await postCerrarReparacion(id, { resolucion });
0104:      await refreshIngreso();
0105:      setErr("");
0106:    } catch (e) {
0107:      setErr(e?.message || "No se pudo guardar la resoluciÃ³n");
0108:    } finally {
0109:      setSavingResol(false);
0110:    }
0111:  }
0112:
0113:  return (
0114:    <div className="border rounded p-4">
